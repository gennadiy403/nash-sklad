# Google Apps Script web app URL (для сохранения в Google Sheets)
VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Telegram бот — уведомления о новых подписчиках
# 1. Создай бота через @BotFather, скопируй токен
# 2. Напиши боту /start, затем зайди на:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Найди "chat":{"id":...} — это твой CHAT_ID
VITE_TG_BOT_TOKEN=1234567890:ABCdef...
VITE_TG_CHAT_ID=123456789
